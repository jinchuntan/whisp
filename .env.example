# ============================================================================
# Whisp — Web/API (Vercel) environment.  Copy to `.env` for local dev, and set
# the same variables in the Vercel dashboard for deployment.
# NEVER commit the real `.env`.  This file contains placeholders only.
# ============================================================================

# ---- Supabase (server-side only) ----
# service_role bypasses RLS — server/worker ONLY. Never expose it to the browser.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=replace-with-service-role-key
SUPABASE_AUDIO_BUCKET=whisp-audio

# anon / publishable key. Used ONLY server-side to call the Supabase Auth REST
# API for host email/password login. It is a public key by design, but Whisp
# keeps the whole auth flow on the server so access/refresh tokens live in
# HttpOnly cookies and never touch JavaScript.
SUPABASE_ANON_KEY=replace-with-anon-public-key

# ---- Host (dashboard) login ----
# Only these Supabase Auth users may sign in to the host console.
# Comma-separated, case-insensitive. Create the user(s) in Supabase Auth first.
ADMIN_EMAIL_ALLOWLIST=host@yourevent.com

# Session cookies (HttpOnly). MUST be true in production (served over HTTPS);
# set to false only for local http://localhost development.
SESSION_COOKIE_SECURE=true
# "lax" is a good default; "strict" is fine too (the dashboard is same-origin).
SESSION_COOKIE_SAMESITE=lax
# Refresh-cookie lifetime in seconds (default 7 days). The access cookie tracks
# the token's own expiry and is refreshed transparently.
SESSION_MAX_AGE_SECONDS=604800

# ---- Badge auth (firmware → API) ----
# Badge firmware sends:  X-Whisp-Key: <BADGE_API_KEY>
BADGE_API_KEY=replace-with-badge-key
BADGE_ID_PATTERN=^[A-Za-z0-9_-]{1,64}$

# ---- Legacy admin API key (compatibility for tests / CLI ONLY) ----
# The browser NEVER uses this. Leave ALLOW_LEGACY_ADMIN_KEY=false in production;
# host access there is by email/password + allowlist only. When enabled, a
# request may send `Authorization: Bearer <ADMIN_API_KEY>`.
ADMIN_API_KEY=replace-with-admin-key
ALLOW_LEGACY_ADMIN_KEY=false

# ---- Upload validation ----
# Vercel functions cap request bodies at 4.5 MB. Keep this at or below that.
MAX_AUDIO_BYTES=4194304

# ---- Display only (the API does NOT transcribe; the worker owns this) ----
# Shown on the dashboard so the host knows which mode the worker will use.
TRANSCRIPTION_MODE=faster_whisper_only

# Seconds since last worker heartbeat before the dashboard shows "offline".
WORKER_OFFLINE_SECONDS=20

# ---- CORS / CSRF origins ----
# Comma-separated list of the exact browser origin(s) that serve the dashboard,
# e.g. https://whispspace.vercel.app. This also drives CSRF Origin/Referer
# checks. "*" is DEV-ONLY: browsers reject wildcard CORS with credentialed
# cookies, so set real origins in production.
CORS_ALLOW_ORIGINS=*
