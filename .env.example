# ============================================================================
# Whisp — Web/API (Vercel) environment.  Copy to `.env` for local dev, and set
# the same variables in the Vercel dashboard for deployment.
# NEVER commit the real `.env`.  This file contains placeholders only.
# ============================================================================

# ---- Supabase (server-side only; service_role bypasses RLS) ----
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=replace-with-service-role-key
SUPABASE_AUDIO_BUCKET=whisp-audio

# ---- Prototype API keys (generate long random strings) ----
# Badge firmware sends:  X-Whisp-Key: <BADGE_API_KEY>
# Dashboard/admin sends: Authorization: Bearer <ADMIN_API_KEY>
BADGE_API_KEY=replace-with-badge-key
ADMIN_API_KEY=replace-with-admin-key

# ---- Upload validation ----
# Vercel functions cap request bodies at 4.5 MB. Keep this at or below that.
MAX_AUDIO_BYTES=4194304
BADGE_ID_PATTERN=^[A-Za-z0-9_-]{1,64}$

# ---- Display only (the API does NOT transcribe; the worker owns this) ----
# Shown on the dashboard so the host knows which mode the worker will use.
TRANSCRIPTION_MODE=faster_whisper_only

# Seconds since last worker heartbeat before the dashboard shows "offline".
WORKER_OFFLINE_SECONDS=20

# CORS origins for the dashboard (comma-separated). "*" is fine for a prototype.
CORS_ALLOW_ORIGINS=*
