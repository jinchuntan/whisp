# ============================================================================
# Persephone WORKER environment (WSL2). Copy to worker/.env. NEVER commit the real .env.
# ============================================================================

# ---- Supabase (service_role; trusted server only) ----
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=replace-with-service-role-key
SUPABASE_AUDIO_BUCKET=persephone-audio

# ---- Transcription mode (authoritative provider selector) ----
# One of: faster_whisper_only | faster_whisper_first | agora_first | agora_only
# Default protects Agora credits. Set agora_first for the live demo.
TRANSCRIPTION_MODE=faster_whisper_only

# ---- Faster-Whisper ----
# Recommended: "small" — badge audio is often whispered/quiet, and "base" was
# insufficient for whispered speech in hardware testing. "small" is more accurate
# but ~2-3x slower on CPU. Use "base" only if you need lower latency for
# normal-volume speech. ("medium" is more accurate still, much slower on CPU.)
FASTER_WHISPER_MODEL=small
FASTER_WHISPER_DEVICE=cpu
FASTER_WHISPER_COMPUTE_TYPE=int8
FASTER_WHISPER_BEAM_SIZE=5
TRANSCRIPTION_LANGUAGE=en

# ---- Provider timeouts (seconds) ----
FASTER_WHISPER_TIMEOUT=120
AGORA_TIMEOUT=60

# ---- Clustering ----
ENABLE_CLUSTERING=true
CLUSTER_SIMILARITY_THRESHOLD=0.78
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ---- Chatbot / voice assistant (independent of TRANSCRIPTION_MODE and Agora) ----
# Generates a short spoken answer for each transcribed question. Browser TTS
# (in the dashboard) reads it aloud; this NEVER uses Agora credit.
#   disabled          -> no chatbot work, zero chatbot network calls (default)
#   mock              -> deterministic local answer (tests/demo, no network)
#   ollama            -> local Ollama model via {BASE_URL}/api/chat
#   openai_compatible -> any OpenAI-compatible {BASE_URL}/chat/completions
CHATBOT_MODE=disabled
# Auto-enqueue an answer for every done+transcribed question. If false, answers
# are only generated when the host clicks "Generate" in the dashboard.
CHATBOT_AUTO_GENERATE=true
# Model name (e.g. llama3.2:3b for Ollama, or a served model id). Not a secret.
CHATBOT_MODEL=
# Base URL. Ollama default is http://localhost:11434 (native /api/chat). For
# openai_compatible set the API base ending in the version, e.g. http://host/v1.
# WSL note: if Ollama runs on WINDOWS and this worker runs in WSL2, "localhost"
# may NOT reach it — use the Windows host IP. Find it in WSL with:
#   grep -m1 nameserver /etc/resolv.conf | awk '{print $2}'
# then set CHATBOT_BASE_URL=http://<that-ip>:11434 (and start Ollama on Windows
# with OLLAMA_HOST=0.0.0.0 so it accepts connections from WSL). See docs/VOICE_ASSISTANT.md.
CHATBOT_BASE_URL=
# Secret — worker-only. Only needed for hosted OpenAI-compatible endpoints.
# Never send to the browser/badge; never log; never commit.
CHATBOT_API_KEY=
CHATBOT_TIMEOUT_SECONDS=30
CHATBOT_MAX_OUTPUT_TOKENS=180
CHATBOT_TEMPERATURE=0.3
CHATBOT_MAX_ATTEMPTS=3

# ---- Clustering agent (agentic AI layer; optional, independent of the above) ----
# An LLM plan->tool-call->act loop that decides clustering by calling tools. The
# existing embedding + cosine search is exposed to it AS a tool; it can then assign
# to an existing cluster, create a new cluster (authoring the label), or flag a
# question out of clustering. Selection is driven ONLY by CLUSTER_MODE.
#   embedding_only -> today's cosine clustering, byte-identical, ZERO LLM calls (default)
#   auto           -> agent_first when the agent is configured, else embedding_only
#   agent_first    -> agent decides; on ANY failure fall back to the embedding path
#   agent_only     -> agent decides, no fallback (tests/demos)
CLUSTER_MODE=embedding_only
#   mock              -> deterministic offline agent loop (no network, no credit)
#   openai_compatible -> any OpenAI-compatible {BASE_URL}/chat/completions with tools
AGENT_PROVIDER=openai_compatible
# Any AGENT_* left blank falls back to the matching CHATBOT_* value, so an already
# configured voice assistant powers the agent with no extra setup.
AGENT_MODEL=
AGENT_BASE_URL=
# Secret — worker-only. Never sent to the browser/badge; never log; never commit.
AGENT_API_KEY=
AGENT_TIMEOUT_SECONDS=30
# Deterministic tool selection.
AGENT_TEMPERATURE=0.0
# Hard safety rails: bound the plan->act loop and the candidate set it can see.
AGENT_MAX_TOOL_CALLS=6
AGENT_MAX_CANDIDATES=12
# Whether the agent may flag a question (off_topic/abusive/not_a_question/unintelligible).
AGENT_ALLOW_FLAG=true

# ---- Loop / lease / heartbeat ----
# WORKER_ID defaults to hostname-pid if left blank.
WORKER_ID=
POLL_INTERVAL_SECONDS=1.0
LEASE_SECONDS=120
HEARTBEAT_INTERVAL_SECONDS=5

# ---- Audio retention ----
AUDIO_RETENTION_HOURS=24
RETENTION_INTERVAL_SECONDS=3600

# ---- Agora (ONLY used when TRANSCRIPTION_MODE selects agora). Never committed. ----
# Secrets — worker-only. Never send to the browser/badge; never log; never commit.
AGORA_APP_ID=
AGORA_APP_CERTIFICATE=
AGORA_CUSTOMER_ID=
AGORA_CUSTOMER_SECRET=

# HARD master switch. Live RTC/STT calls REFUSE to run unless this is true, even
# in an agora_* mode with credentials present. Keep false until you deliberately
# test (see docs/AGORA_SETUP.md) and turn it back to false afterwards.
AGORA_LIVE_ENABLED=false

# RTC UIDs: the worker publishes badge audio as AGORA_WORKER_UID; Agora's STT
# bots join as the sub/pub bot UIDs.
AGORA_WORKER_UID=20001
AGORA_SUB_BOT_UID=10001
AGORA_PUB_BOT_UID=10002

# Short-lived RTC token lifetime (seconds).
AGORA_TOKEN_TTL_SECONDS=300

# Credit safety: max seconds of audio published per job, REST idle time, overall
# task timeout, and the max number of live Agora jobs per UTC day.
AGORA_MAX_DURATION_SECONDS=12
AGORA_IDLE_SECONDS=10
AGORA_TIMEOUT=30
AGORA_DAILY_MAX_JOBS=20

# Hard cap (seconds) for the manual live canary tool.
AGORA_CANARY_MAX_SECONDS=3

LOG_LEVEL=INFO
