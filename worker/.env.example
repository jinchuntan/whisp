# ============================================================================
# Persephone WORKER environment (WSL2). Copy to worker/.env. NEVER commit the real .env.
# ============================================================================

# ---- Supabase (service_role; trusted server only) ----
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=replace-with-service-role-key
SUPABASE_AUDIO_BUCKET=persephone-audio

# ---- Transcription mode (authoritative provider selector) ----
# One of: faster_whisper_only | faster_whisper_first | agora_first | agora_only
# Default protects Agora credits. Set agora_first for the live demo.
TRANSCRIPTION_MODE=faster_whisper_only

# ---- Faster-Whisper ----
# Recommended: "small" — badge audio is often whispered/quiet, and "base" was
# insufficient for whispered speech in hardware testing. "small" is more accurate
# but ~2-3x slower on CPU. Use "base" only if you need lower latency for
# normal-volume speech. ("medium" is more accurate still, much slower on CPU.)
FASTER_WHISPER_MODEL=small
FASTER_WHISPER_DEVICE=cpu
FASTER_WHISPER_COMPUTE_TYPE=int8
FASTER_WHISPER_BEAM_SIZE=5
TRANSCRIPTION_LANGUAGE=en

# ---- Provider timeouts (seconds) ----
FASTER_WHISPER_TIMEOUT=120
AGORA_TIMEOUT=60

# ---- Clustering ----
ENABLE_CLUSTERING=true
CLUSTER_SIMILARITY_THRESHOLD=0.78
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ---- Loop / lease / heartbeat ----
# WORKER_ID defaults to hostname-pid if left blank.
WORKER_ID=
POLL_INTERVAL_SECONDS=1.0
LEASE_SECONDS=120
HEARTBEAT_INTERVAL_SECONDS=5

# ---- Audio retention ----
AUDIO_RETENTION_HOURS=24
RETENTION_INTERVAL_SECONDS=3600

# ---- Agora (ONLY used when TRANSCRIPTION_MODE selects agora). Never committed. ----
# Secrets — worker-only. Never send to the browser/badge; never log; never commit.
AGORA_APP_ID=
AGORA_APP_CERTIFICATE=
AGORA_CUSTOMER_ID=
AGORA_CUSTOMER_SECRET=

# HARD master switch. Live RTC/STT calls REFUSE to run unless this is true, even
# in an agora_* mode with credentials present. Keep false until you deliberately
# test (see docs/AGORA_SETUP.md) and turn it back to false afterwards.
AGORA_LIVE_ENABLED=false

# RTC UIDs: the worker publishes badge audio as AGORA_WORKER_UID; Agora's STT
# bots join as the sub/pub bot UIDs.
AGORA_WORKER_UID=20001
AGORA_SUB_BOT_UID=10001
AGORA_PUB_BOT_UID=10002

# Short-lived RTC token lifetime (seconds).
AGORA_TOKEN_TTL_SECONDS=300

# Credit safety: max seconds of audio published per job, REST idle time, overall
# task timeout, and the max number of live Agora jobs per UTC day.
AGORA_MAX_DURATION_SECONDS=12
AGORA_IDLE_SECONDS=10
AGORA_TIMEOUT=30
AGORA_DAILY_MAX_JOBS=20

# Hard cap (seconds) for the manual live canary tool.
AGORA_CANARY_MAX_SECONDS=3

LOG_LEVEL=INFO
