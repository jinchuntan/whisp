# ============================================================================
# Whisp WORKER environment (WSL2). Copy to worker/.env. NEVER commit the real .env.
# ============================================================================

# ---- Supabase (service_role; trusted server only) ----
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=replace-with-service-role-key
SUPABASE_AUDIO_BUCKET=whisp-audio

# ---- Transcription mode (authoritative provider selector) ----
# One of: faster_whisper_only | faster_whisper_first | agora_first | agora_only
# Default protects Agora credits. Set agora_first for the live demo.
TRANSCRIPTION_MODE=faster_whisper_only

# ---- Faster-Whisper ----
FASTER_WHISPER_MODEL=base
FASTER_WHISPER_DEVICE=cpu
FASTER_WHISPER_COMPUTE_TYPE=int8
FASTER_WHISPER_BEAM_SIZE=5
TRANSCRIPTION_LANGUAGE=en

# ---- Provider timeouts (seconds) ----
FASTER_WHISPER_TIMEOUT=120
AGORA_TIMEOUT=60

# ---- Clustering ----
ENABLE_CLUSTERING=true
CLUSTER_SIMILARITY_THRESHOLD=0.78
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ---- Loop / lease / heartbeat ----
# WORKER_ID defaults to hostname-pid if left blank.
WORKER_ID=
POLL_INTERVAL_SECONDS=1.0
LEASE_SECONDS=120
HEARTBEAT_INTERVAL_SECONDS=5

# ---- Audio retention ----
AUDIO_RETENTION_HOURS=24
RETENTION_INTERVAL_SECONDS=3600

# ---- Agora (ONLY used when TRANSCRIPTION_MODE selects agora). Never committed. ----
AGORA_APP_ID=
AGORA_APP_CERTIFICATE=
AGORA_CUSTOMER_ID=
AGORA_CUSTOMER_SECRET=
AGORA_MAX_DURATION_SECONDS=30
AGORA_IDLE_SECONDS=10

LOG_LEVEL=INFO
